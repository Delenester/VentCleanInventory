@{
    ViewData["Title"] = "Заявка отправлена";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-hourglass-split text-warning" style="font-size: 4rem;"></i>
                    </div>
                    <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                    <p class="text-muted mb-4">
                        Ваша регистрация принята. Администратор проверит данные организации (УНП, адрес) и одобрит учётную запись.
                        После одобрения вы сможете войти в личный кабинет.
                    </p>
                    <a asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Перейти ко входу
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
