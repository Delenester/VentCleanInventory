@model VentCleanInventory.Web.Areas.Client.Models.ClientRequestViewModel
@using VentCleanInventory.Web.Areas.Client.Models
@{
    ViewData["Title"] = "Оставить заявку";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <a asp-area="Client" asp-controller="ClientHome" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="ObjectName" class="form-label fw-semibold"></label>
                        <input asp-for="ObjectName" class="form-control" placeholder="Например: ТЦ Мега, Офис на Промышленной" />
                        <span asp-validation-for="ObjectName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ObjectAddress" class="form-label fw-semibold"></label>
                        <input asp-for="ObjectAddress" class="form-control" placeholder="Например: г. Минск, ул. Промышленная 15" />
                        <span asp-validation-for="ObjectAddress" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="ServiceType" class="form-label fw-semibold"></label>
                            <select asp-for="ServiceType" class="form-select" id="serviceType">
                                <option value="">— Выберите тип услуги —</option>
                                @foreach (var st in ClientRequestViewModel.ServiceTypes)
                                {
                                    <option value="@st" data-price="@VentCleanInventory.Web.Data.ServicePriceList.GetPrice(st)">@st</option>
                                }
                            </select>
                            <span asp-validation-for="ServiceType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Area" class="form-label fw-semibold"></label>
                            <input asp-for="Area" type="number" step="0.01" min="0" class="form-control" id="area" placeholder="Например: 150.50" />
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>
                    <div id="priceEstimate" class="alert alert-info">
                        <label class="form-label fw-semibold mb-2">Предварительная стоимость</label>
                        <div class="input-group">
                            <input asp-for="EstimatedCost" type="number" step="0.01" min="0" class="form-control fs-5 fw-bold" id="estimatedPrice" />
                            <span class="input-group-text">руб.</span>
                        </div>
                        <small class="text-muted mt-1 d-block">Рассчитано автоматически на основе тарифа × площадь. Менеджер скорректирует при одобрении.</small>
                        <span asp-validation-for="EstimatedCost" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ZoneName" class="form-label fw-semibold"></label>
                        <input asp-for="ZoneName" class="form-control" placeholder="Например: 1 этаж — холл, Цех №3" />
                        <span asp-validation-for="ZoneName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Опишите что нужно сделать: какие работы, в каком объёме, особенности доступа и т.д."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="BlueprintPhoto" class="form-label fw-semibold">Фото / чертёж</label>
                        <input asp-for="BlueprintPhoto" type="file" class="form-control" accept="image/*,.pdf" />
                        <small class="text-muted">Изображение или PDF (макс. 10 МБ)</small>
                        <span asp-validation-for="BlueprintPhoto" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-send me-1"></i> Отправить заявку
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-info">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-info-circle me-1"></i> Как это работает</h5>
                <ol class="mb-0 small">
                    <li class="mb-2">Вы отправляете заявку с описанием проблемы</li>
                    <li class="mb-2">Диспетчер проверяет заявку и одобряет</li>
                    <li class="mb-2">Мастер выезжает на объект и выполняет работы</li>
                    <li class="mb-2">Результат фиксируется в системе</li>
                </ol>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const prices = {
            @foreach (var st in ClientRequestViewModel.ServiceTypes)
            {
                @:$("@st"): @VentCleanInventory.Web.Data.ServicePriceList.GetPrice(st),
            }
        };
        const serviceType = document.getElementById('serviceType');
        const area = document.getElementById('area');
        const priceInput = document.getElementById('estimatedPrice');
        function updatePrice() {
            const st = serviceType.value;
            const a = parseFloat(area.value) || 0;
            if (st && a > 0) {
                const total = (prices[st] || 10) * a;
                priceInput.value = total.toFixed(2);
            } else {
                priceInput.value = '';
            }
        }
        serviceType.addEventListener('change', updatePrice);
        area.addEventListener('input', updatePrice);
        updatePrice();
    </script>
}
