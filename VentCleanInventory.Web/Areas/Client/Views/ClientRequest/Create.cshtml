@model VentCleanInventory.Web.Areas.Client.Models.ClientRequestViewModel
@using VentCleanInventory.Web.Areas.Client.Models
@{
    ViewData["Title"] = "Оставить заявку";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <a asp-area="Client" asp-controller="ClientHome" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="ObjectName" class="form-label fw-semibold"></label>
                        <input asp-for="ObjectName" class="form-control" placeholder="Например: ТЦ Мега, Офис на Промышленной" />
                        <span asp-validation-for="ObjectName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ObjectAddress" class="form-label fw-semibold"></label>
                        <input asp-for="ObjectAddress" class="form-control" placeholder="Например: г. Минск, ул. Промышленная 15" />
                        <span asp-validation-for="ObjectAddress" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="ServiceType" class="form-label fw-semibold"></label>
                            <select asp-for="ServiceType" class="form-select" id="serviceType">
                                <option value="">— Выберите тип услуги —</option>
                                @foreach (var st in ClientRequestViewModel.ServiceTypes)
                                {
                                    <option value="@st" data-price="@VentCleanInventory.Web.Data.ServicePriceList.GetPrice(st)">@st</option>
                                }
                            </select>
                            <span asp-validation-for="ServiceType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Area" class="form-label fw-semibold"></label>
                            <input asp-for="Area" type="number" step="0.01" min="0" class="form-control" id="area" placeholder="Например: 150.50" />
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>
                    <div id="priceEstimate" class="alert alert-info">
                        <label class="form-label fw-semibold mb-2">Предварительная стоимость</label>
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-3 fw-bold" id="estimatedPrice">—</span>
                            <span class="fs-5 text-muted">руб.</span>
                        </div>
                        <small class="text-muted mt-1 d-block">Рассчитано автоматически. Окончательная цена устанавливается менеджером при одобрении.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ZoneName" class="form-label fw-semibold"></label>
                        <input asp-for="ZoneName" class="form-control" placeholder="Например: 1 этаж — холл, Цех №3" />
                        <span asp-validation-for="ZoneName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Опишите что нужно сделать: какие работы, в каком объёме, особенности доступа и т.д."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="BlueprintPhoto" class="form-label fw-semibold">Фото / чертёж</label>
                        <input asp-for="BlueprintPhoto" type="file" class="form-control" accept="image/*,.pdf" />
                        <small class="text-muted">Изображение или PDF (макс. 10 МБ)</small>
                        <span asp-validation-for="BlueprintPhoto" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-send me-1"></i> Отправить заявку
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-info mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-info-circle me-1"></i> Как это работает</h5>
                <ol class="mb-0 small">
                    <li class="mb-2">Вы отправляете заявку с описанием проблемы</li>
                    <li class="mb-2">Менеджер проверяет заявку и одобряет</li>
                    <li class="mb-2">Мастер выезжает на объект и выполняет работы</li>
                    <li class="mb-2">Результат фиксируется в системе</li>
                </ol>
            </div>
        </div>
        <div class="card border-secondary">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-file-text me-1"></i> Условия договора</h5>
                <p class="small text-muted mb-2">Ознакомьтесь с типовыми условиями договора перед отправкой заявки.</p>
                <button type="button" class="btn btn-outline-primary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#contractModal">
                    <i class="bi bi-eye me-1"></i> Посмотреть условия
                </button>
            </div>
        </div>
    </div>
</div>

@* Contract terms modal *@
<div class="modal fade" id="contractModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Типовой договор на выполнение работ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body small">
                <p class="text-end mb-2">г. Минск &nbsp;&nbsp;&nbsp; "___" _________ 20__ г.</p>

                <p><strong>Общество с ограниченной ответственностью «VentClean»</strong> (УНП 123456789), именуемое в дальнейшем «Исполнитель», в лице Директора Иванова И.И., действующего на основании Устава, с одной стороны, и <strong>Заказчик</strong>, с другой стороны, заключили настоящий договор о нижеследующем:</p>

                <h6>1. ПРЕДМЕТ ДОГОВОРА</h6>
                <p>1.1. Исполнитель обязуется по заданию Заказчика выполнить работы по чистке, промывке и обслуживанию вентиляционных систем и воздуховодов, а Заказчик обязуется принять результат Работ и оплатить его.</p>
                <p>1.2. Объект, объём и вид Работ указываются в заявке Заказчика, являющейся неотъемлемой частью договора.</p>

                <h6>2. ЦЕНА И ПОРЯДОК РАСЧЁТОВ</h6>
                <p>2.1. Стоимость Работ определяется в соответствии с утверждённым прайс-листом Исполнителя и указывается в договоре при его одобрении менеджером.</p>
                <p>2.2. Оплата производится в течение 5 (пяти) банковских дней с даты подписания сторонами акта сдачи-приёмки выполненных Работ.</p>

                <h6>3. СРОКИ ВЫПОЛНЕНИЯ</h6>
                <p>3.1. Сроки выполнения Работ согласовываются сторонами дополнительно и указываются в договоре.</p>

                <h6>4. ОТВЕТСТВЕННОСТЬ СТОРОН</h6>
                <p>4.1. Исполнитель гарантирует качество выполненных Работ в течение 12 (двенадцати) месяцев с даты подписания акта сдачи-приёмки.</p>
                <p>4.2. За нарушение сроков выполнения Работ Исполнитель уплачивает Заказчику пеню в размере 0,1% от стоимости невыполненных Работ за каждый день просрочки, но не более 10% от стоимости Работ.</p>

                <h6>5. ПРОЧИЕ УСЛОВИЯ</h6>
                <p>5.1. Договор вступает в силу с даты его подписания Сторонами и действует до полного исполнения обязательств.</p>
                <p>5.2. Все споры разрешаются путём переговоров, при недостижении согласия — в Экономическом суде г. Минска.</p>
                <p>5.3. Договор составлен в двух экземплярах, имеющих одинаковую юридическую силу.</p>

                <p class="text-muted mt-3 mb-0"><em>Полный текст договора формируется после одобрения заявки менеджером и доступен для скачивания в личном кабинете.</em></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const serviceType = document.getElementById('serviceType');
        const area = document.getElementById('area');
        const priceSpan = document.getElementById('estimatedPrice');
        function updatePrice() {
            const st = serviceType.value;
            const a = parseFloat(area.value) || 0;
            if (st && a > 0) {
                const sel = serviceType.options[serviceType.selectedIndex];
                const price = parseFloat(sel.dataset.price) || 10;
                priceSpan.textContent = (price * a).toFixed(2);
            } else {
                priceSpan.textContent = '—';
            }
        }
        serviceType.addEventListener('change', updatePrice);
        area.addEventListener('input', updatePrice);
        updatePrice();
    </script>
}
