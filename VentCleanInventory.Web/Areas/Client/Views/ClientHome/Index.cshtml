@model VentCleanInventory.Web.Areas.Client.Models.ClientPortalViewModel
@using VentCleanInventory.Web.Data

@{
    ViewData["Title"] = "Личный кабинет клиента";
}

<style>
    .req-card { border: 1px solid #e9ecef; border-radius: 12px; padding: 1rem; margin-bottom: 0.75rem; background: #fff; }
    .req-card-header { display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem; }
    .req-card-title { font-weight: 600; color: #212529; }
    .req-card-meta { font-size: 0.85rem; color: #6c757d; }
    .req-card-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
    @@media (max-width: 576px) {
        .req-card-actions { flex-direction: column; }
        .req-card-actions .btn { width: 100%; }
        .req-card-header { flex-direction: column; }
    }
</style>

<div class="page-header">
    <h1 class="m-0">@ViewData["Title"]</h1>
    <p class="text-muted mb-0 mt-1">Информация об организации, договорах и заявках</p>
</div>

@if (Model.Notifications.Any())
{
    <div class="card border-warning mb-4">
        <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-bell me-2"></i>Уведомления (@Model.Notifications.Count непрочитанных)</h5>
            <form asp-action="MarkAllRead" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-warning">Отметить все как прочитанные</button>
            </form>
        </div>
        <div class="card-body p-0">
            @foreach (var n in Model.Notifications)
            {
                <div class="d-flex align-items-start p-3 border-bottom">
                    <i class="bi bi-bell text-warning me-3 mt-1"></i>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@n.Title</div>
                        <div class="text-muted small">@n.Message</div>
                        <div class="text-muted small mt-1">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                    <form asp-action="MarkRead" asp-route-id="@n.Id" method="post" class="ms-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Прочитано">
                            <i class="bi bi-check-lg"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
}

@if (Model.Client is null)
{
    <div class="alert alert-warning">Организация не привязана к учётной записи. Обратитесь к администратору.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-header">Организация</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">УНП</div>
                    <div class="fw-semibold">@Model.Client.Unp</div>
                </div>
                <div class="col-md-8">
                    <div class="text-muted small">Наименование</div>
                    <div class="fw-semibold">@Model.Client.Name</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small">Юридический адрес</div>
                    <div>@Model.Client.LegalAddress</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Client.ContactInfo))
                {
                    <div class="col-12">
                        <div class="text-muted small">Контакты</div>
                        <div>@Model.Client.ContactInfo</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Requests card list ── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="bi bi-file-text me-1"></i>Ваши заявки</span>
            <span class="small">
                @{
                    var newCount = Model.Requests.Count(r => r.RequestStatusValue == RequestStatus.New);
                    var activeCount = Model.Requests.Count(r => r.RequestStatusValue is RequestStatus.Approved or RequestStatus.ClientConfirmed or RequestStatus.Assigned or RequestStatus.InProgress);
                }
                @if (newCount > 0) { <span class="badge bg-warning text-dark me-1">@newCount новых</span> }
                @if (activeCount > 0) { <span class="badge bg-primary me-1">@activeCount в работе</span> }
                <a asp-area="Client" asp-controller="ClientRequest" asp-action="Index" class="btn btn-sm btn-outline-secondary ms-2">Все заявки</a>
            </span>
        </div>
        <div class="card-body p-3">
            @if (!Model.Requests.Any())
            {
                <div class="text-muted text-center py-3">Нет заявок</div>
            }
            else
            {
                @foreach (var r in Model.Requests.Take(10))
                {
                    <div class="req-card">
                        <div class="req-card-header">
                            <div>
                                <div class="req-card-title">#@r.Id &middot; @r.WorkObject?.Name</div>
                                <div class="req-card-meta">@r.Date.ToString("dd.MM.yyyy")</div>
                            </div>
                            @switch (r.RequestStatusValue)
                            {
                                case RequestStatus.New:
                                    <span class="badge bg-warning text-dark">Новая</span>
                                    break;
                                case RequestStatus.Approved:
                                    <span class="badge bg-success">Одобрена</span>
                                    break;
                                case RequestStatus.ClientConfirmed:
                                    <span class="badge bg-info text-dark">Подтверждена</span>
                                    break;
                                case RequestStatus.Assigned:
                                    <span class="badge bg-primary">Назначена</span>
                                    break;
                                case RequestStatus.InProgress:
                                    <span class="badge bg-secondary">В работе</span>
                                    break;
                                case RequestStatus.Completed:
                                    <span class="badge bg-success">Выполнена</span>
                                    break;
                                case RequestStatus.Rejected:
                                    <span class="badge bg-danger">Отклонена</span>
                                    break;
                            }
                        </div>
                        <div class="req-card-meta d-flex flex-wrap gap-3">
                            @if (r.EstimatedCost.HasValue)
                            {
                                <span><i class="bi bi-currency-ruble"></i> @r.EstimatedCost.Value.ToString("N2") руб.</span>
                            }
                            <span><i class="bi bi-person"></i> @(Model.RequestMasterNames.GetValueOrDefault(r.AssignedMasterId ?? "", "—"))</span>
                        </div>
                        <div class="req-card-actions">
                            <a asp-area="Client" asp-controller="ClientRequest" asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-eye"></i> Подробнее
                            </a>
                            @if (!string.IsNullOrWhiteSpace(r.ContractNumber))
                            {
                                <a asp-area="Manager" asp-controller="Contract" asp-action="Export" asp-route-id="@r.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-download"></i> Договор
                                </a>
                                @if (r.RequestStatusValue == RequestStatus.Approved)
                                {
                                    <form asp-action="ConfirmContract" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-check2-circle"></i> Подтвердить договор
                                        </button>
                                    </form>
                                }
                            }
                            @if (r.RequestStatusValue == RequestStatus.New)
                            {
                                <form asp-action="CancelRequest" asp-route-id="@r.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Отменить заявку №@r.Id?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-x-circle"></i> Отменить
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
                @if (Model.Requests.Count > 10)
                {
                    <div class="text-center mt-2">
                        <a asp-area="Client" asp-controller="ClientRequest" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                            Показать все заявки (@Model.Requests.Count)
                        </a>
                    </div>
                }
            }
        </div>
    </div>

    @* ── Completed work cards ── *@
    <div class="card">
        <div class="card-header"><i class="bi bi-check2-all me-1"></i>Выполненные работы мастерами</div>
        <div class="card-body p-3">
            @if (!Model.CompletedWork.Any())
            {
                <div class="text-muted text-center py-3">Нет выполненных работ</div>
            }
            else
            {
                @foreach (var w in Model.CompletedWork)
                {
                    <div class="req-card" role="button" onclick="window.location.href='@Url.Action("Details", "WorkReport", new { area = "Client", id = w.WorkLogId })'">
                        <div class="req-card-header">
                            <div>
                                <div class="req-card-title">@w.ObjectName</div>
                                <div class="req-card-meta">@w.WorkDate.ToString("dd.MM.yyyy") &middot; @(w.ZoneName ?? "—")</div>
                            </div>
                            <span class="badge bg-success">Выполнено</span>
                        </div>
                        <div class="req-card-meta d-flex flex-wrap gap-3">
                            @if (w.Meters.HasValue) { <span><i class="bi bi-rulers"></i> @w.Meters.Value.ToString("N2") м</span> }
                            @if (w.Grids.HasValue) { <span><i class="bi bi-grid-3x3"></i> @w.Grids решёт.</span> }
                            @if (!string.IsNullOrWhiteSpace(w.MaterialsUsed)) { <span><i class="bi bi-box-seam"></i> @w.MaterialsUsed</span> }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(w.PhotoPath))
                        {
                            <div class="mt-2">
                                <a href="@w.PhotoPath" target="_blank">
                                    <img src="@w.PhotoPath" class="img-thumbnail" style="max-height:60px;" alt="Фото" />
                                </a>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}
