@model VentCleanInventory.Web.Areas.Supplier.Models.SupplyRequestConfirmViewModel

@{
    ViewData["Title"] = $"Подтверждение запроса {Model.RequestNumber}";
    var allPiece = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { "шт", "шт.", "штук", "ед", "ед.", "комплект", "компл." };
}

<div class="page-header d-flex align-items-center gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="m-0">@ViewData["Title"]</h1>
</div>

<div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    Укажите количество и цену, которую можете поставить. Количество не может превышать запрошенное.
</div>

<form asp-action="Confirm" asp-route-id="@Model.RequestId" method="post" class="decimal-fix">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="RequestId" />
    <input type="hidden" asp-for="RequestNumber" />

    <div class="card">
        <div class="card-header"><i class="bi bi-cart me-1"></i>Позиции</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Наименование</th>
                            <th class="text-center">Запрошено</th>
                            <th class="text-center">Ед.</th>
                            <th class="text-center" style="width:120px;">Поставляю</th>
                            <th class="text-center" style="width:130px;">Цена за ед.</th>
                            <th>Примечание</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Items.Count; i++)
                        {
                            var isPiece = allPiece.Contains(Model.Items[i].Unit?.Trim().ToLower() ?? "");
                            var step = isPiece ? "1" : "0.01";
                            var fmt = isPiece ? "N0" : "N2";
                            var maxVal = Model.Items[i].OrderedQuantity;

                            <tr>
                                <td>
                                    <div class="fw-semibold">@Model.Items[i].NomenclatureName</div>
                                    <input type="hidden" name="Items[@i].SupplyRequestItemId" value="@Model.Items[i].SupplyRequestItemId" />
                                    <input type="hidden" name="Items[@i].NomenclatureName" value="@Model.Items[i].NomenclatureName" />
                                    <input type="hidden" name="Items[@i].OrderedQuantity" value="@Model.Items[i].OrderedQuantity" />
                                    <input type="hidden" name="Items[@i].Unit" value="@Model.Items[i].Unit" />
                                </td>
                                <td class="text-center fw-semibold">@Model.Items[i].OrderedQuantity.ToString(fmt)</td>
                                <td class="text-center text-muted">@Model.Items[i].Unit</td>
                                <td>
                                    <input type="text" inputmode="decimal" name="Items[@i].ConfirmedQuantity"
                                           value="@Model.Items[i].ConfirmedQuantity.ToString(fmt)"
                                           step="@step" min="0" max="@maxVal.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                           class="form-control form-control-sm dec-input text-end qty-input" data-idx="@i" data-max="@maxVal" />
                                    <div class="text-danger small mt-1" style="display:none" id="qty-warn-@i">
                                        <i class="bi bi-exclamation-triangle"></i> Макс. @maxVal.ToString(fmt)
                                    </div>
                                </td>
                                <td>
                                    <input type="text" inputmode="decimal" name="Items[@i].UnitPrice" value=""
                                           class="form-control form-control-sm dec-input text-end" style="width:110px" required
                                           placeholder="0.00" />
                                </td>
                                <td>
                                    <input type="text" name="Items[@i].Note" value="@(Model.Items[i].Note ?? "")"
                                           class="form-control form-control-sm" placeholder="Комментарий..." />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label asp-for="Note" class="form-label fw-semibold">Общий комментарий к заказу</label>
                    <textarea asp-for="Note" class="form-control" rows="2" style="max-width:400px" placeholder="Дополнительная информация..."></textarea>
                </div>
                <div class="col-md-6 text-md-end">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check2-circle me-1"></i> Подтвердить
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Отмена</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    function parseDec(v) { return parseFloat((v || '').replace(',', '.')); }

    document.querySelector('form.decimal-fix').addEventListener('submit', function(e) {
        var decs = this.querySelectorAll('.dec-input');
        for (var i = 0; i < decs.length; i++) {
            if (decs[i].value) decs[i].value = decs[i].value.replace('.', ',');
        }
    });

    document.querySelectorAll('.qty-input').forEach(function(inp) {
        var max = parseFloat(inp.dataset.max);
        var idx = inp.dataset.idx;
        var warn = document.getElementById('qty-warn-' + idx);
        function check() {
            var v = parseDec(inp.value);
            if (!isNaN(v) && v > max) {
                inp.classList.add('is-invalid');
                if (warn) warn.style.display = 'block';
            } else {
                inp.classList.remove('is-invalid');
                if (warn) warn.style.display = 'none';
            }
        }
        inp.addEventListener('input', check);
        inp.closest('form').addEventListener('submit', function(e) {
            check();
            if (inp.classList.contains('is-invalid')) e.preventDefault();
        });
    });
</script>
}
