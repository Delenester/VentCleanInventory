@model IReadOnlyList<VentCleanInventory.Web.Data.Entities.DefectReport>
@{
    ViewData["Title"] = "Брак";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h1 class="m-0">@ViewData["Title"]</h1>
            <p class="text-muted mb-0 mt-1">Зафиксированные дефекты и поломки</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Записать брак
        </a>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-muted text-center py-5">
            <i class="bi bi-check-circle" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="mt-3 mb-0">Дефектов не зафиксировано</p>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var d in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(d.PhotoPath))
                    {
                        <a href="@d.PhotoPath" target="_blank">
                            <img src="@d.PhotoPath" class="card-img-top" style="max-height: 200px; object-fit: cover;" alt="Фото брака" />
                        </a>
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title mb-0">@d.WorkObject.Name</h6>
                            <small class="text-muted">@d.CreatedAt.ToString("dd.MM.yyyy")</small>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(d.ZoneName))
                        {
                            <div class="mb-2"><span class="badge bg-secondary">@d.ZoneName</span></div>
                        }
                        <p class="card-text small">@d.Description</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <form asp-action="Delete" asp-route-id="@d.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Удалить этот отчёт?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Удалить
                            </button>
                        </form>
                        @if (!string.IsNullOrWhiteSpace(d.PhotoPath))
                        {
                            <a href="@d.PhotoPath" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-image"></i> Фото
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
