@model VentCleanInventory.Web.Areas.Master.Models.MyWorkViewModel

@{
    ViewData["Title"] = "Мои работы";
}

<style>
    .work-card { border: 1px solid #e9ecef; border-radius: 12px; padding: 1rem; margin-bottom: 0.75rem; background: #fff; }
    .work-card-header { display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.5rem; }
    .work-card-title { font-weight: 600; color: #212529; }
    .work-card-meta { font-size: 0.85rem; color: #6c757d; }
    .work-card-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
    .photo-upload-btn { position: relative; overflow: hidden; display: inline-flex; align-items: center; gap: 0.375rem; }
    .photo-upload-btn input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
    .photo-upload-btn .btn-content { pointer-events: none; }
    @@media (max-width: 576px) {
        .work-card-actions { flex-direction: column; }
        .work-card-actions .btn { width: 100%; }
    }
</style>

<div class="page-header">
    <h1 class="m-0">@ViewData["Title"]</h1>
    <p class="text-muted mb-0 mt-1">Выполнение работ и фотоотчёты</p>
</div>

@if (TempData["Info"] is string info)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @info
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-tools me-1"></i>Выполнение работ</h5>
    <a asp-area="Master" asp-controller="Work" asp-action="Consume" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-circle"></i> Добавить работу
    </a>
</div>

@if (Model.InProgress.Count == 0)
{
    <div class="card mb-4">
        <div class="card-body text-muted">Нет незавершённых работ. Начните новую через «Добавить работу».</div>
    </div>
}
else
{
    @foreach (var w in Model.InProgress)
    {
        <a asp-action="Details" asp-route-id="@w.Id" class="text-decoration-none">
        <div class="work-card">
            <div class="work-card-header">
                <div>
                    <div class="work-card-title">@w.WorkObject.Name</div>
                    <div class="work-card-meta">@w.WorkDate.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>
            <div class="work-card-meta">
                @if (!string.IsNullOrWhiteSpace(w.ZoneName)) { <span class="me-3"><i class="bi bi-geo-alt"></i> @w.ZoneName</span> }
                @if (w.Meters.HasValue) { <span class="me-3"><i class="bi bi-rulers"></i> @w.Meters.Value.ToString("N2") м</span> }
                @if (w.Grids.HasValue) { <span class="me-3"><i class="bi bi-grid-3x3"></i> @w.Grids решёт.</span> }
            </div>
            @if (!string.IsNullOrWhiteSpace(w.MaterialsUsed))
            {
                <div class="small text-muted mt-1"><i class="bi bi-box-seam"></i> @w.MaterialsUsed</div>
            }
            <div class="work-card-actions">
                <a asp-area="Master" asp-controller="Checklist" asp-action="ForWork" asp-route-workLogId="@w.Id" class="btn btn-outline-warning btn-sm" onclick="event.stopPropagation();">
                    <i class="bi bi-list-check"></i> Чек-лист
                </a>
            </div>
        </div>
        </a>
    }
}

<h5 class="mt-4 mb-3"><i class="bi bi-check2-all me-1"></i>Выполненные</h5>

@if (Model.Completed.Count == 0)
{
    <div class="card">
        <div class="card-body text-muted">Нет выполненных работ.</div>
    </div>
}
else
{
@foreach (var w in Model.Completed)
{
    <a asp-action="Details" asp-route-id="@w.Id" class="text-decoration-none">
    <div class="work-card">
        <div class="work-card-header">
            <div>
                <div class="work-card-title">@w.WorkObject.Name</div>
                <div class="work-card-meta">@w.WorkDate.ToString("dd.MM.yyyy")</div>
            </div>
            <span class="badge bg-success">Выполнено</span>
        </div>
        <div class="work-card-meta">
            @if (!string.IsNullOrWhiteSpace(w.ZoneName)) { <span class="me-3"><i class="bi bi-geo-alt"></i> @w.ZoneName</span> }
            @if (w.Meters.HasValue) { <span class="me-3"><i class="bi bi-rulers"></i> @w.Meters.Value.ToString("N2") м</span> }
            @if (w.Grids.HasValue) { <span class="me-3"><i class="bi bi-grid-3x3"></i> @w.Grids решёт.</span> }
        </div>
        @if (!string.IsNullOrWhiteSpace(w.PhotoPath))
        {
            <div class="mt-2">
                <a href="@w.PhotoPath" target="_blank" onclick="event.stopPropagation();">
                    <img src="@w.PhotoPath" class="img-thumbnail" style="max-height:80px;" alt="Фото" />
                </a>
                </div>
            }
        </div>
    </a>
    }
}
