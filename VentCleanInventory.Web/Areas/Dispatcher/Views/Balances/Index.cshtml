@model VentCleanInventory.Web.Areas.Dispatcher.Models.Balances.BalancesIndexViewModel

@{
    ViewData["Title"] = "Остатки";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Dispatcher" asp-controller="DispatcherHome" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Позиций</div>
                <div class="fs-4 fw-bold">@Model.TotalPositions</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Общее кол-во</div>
                <div class="fs-4 fw-bold">@Model.TotalQuantity.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100 border-warning">
            <div class="card-body">
                <div class="text-muted small">Срок &lt; 30 дней</div>
                <div class="fs-4 fw-bold text-warning">@Model.ExpiringSoonCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Номенклатур</div>
                <div class="fs-4 fw-bold">@Model.SummaryByNomenclature.Count</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 vci-touch-form">
            <div class="col-12 col-md-4">
                <label class="form-label">Склад</label>
                <select class="form-select" name="WarehouseId">
                    <option value="">— все —</option>
                    @foreach (var w in Model.Warehouses)
                    {
                        <option value="@w.Id" selected="@(Model.WarehouseId == w.Id)">@w.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Номенклатура</label>
                <select class="form-select" name="NomenclatureId">
                    <option value="">— вся —</option>
                    @foreach (var n in Model.Nomenclatures)
                    {
                        <option value="@n.Id" selected="@(Model.NomenclatureId == n.Id)">@n.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Срок годности до</label>
                <input class="form-control" type="date" name="ExpirationBefore" value="@Model.ExpirationBefore?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i>Показать
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.SummaryByNomenclature.Any())
{
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart me-2"></i>Сводка по номенклатуре</div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Номенклатура</th>
                        <th class="text-end">Всего</th>
                        <th class="text-end">Складов</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.SummaryByNomenclature)
                    {
                        <tr>
                            <td>@s.ItemName</td>
                            <td class="text-end fw-semibold">@s.TotalQuantity @s.Unit</td>
                            <td class="text-end">@s.WarehouseCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">Детализация остатков</div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>Склад</th>
                <th>Номенклатура</th>
                <th>Инв. № / Партия</th>
                <th>Тип</th>
                <th>Срок годности</th>
                <th class="text-end">Кол-во</th>
            </tr>
            </thead>
            <tbody>
            @if (!Model.Rows.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="bi bi-inbox d-block mb-2" style="font-size: 2rem;"></i>
                        Нет данных
                    </td>
                </tr>
            }
            else
            {
                @foreach (var r in Model.Rows)
                {
                    <tr>
                        <td>@r.WarehouseName</td>
                        <td class="fw-semibold">@r.ItemName</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.SerialOrBatch))
                            {
                                <code>@r.SerialOrBatch</code>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (r.IsEquipment)
                            {
                                <span class="badge bg-info">Оборудование</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Материал</span>
                            }
                        </td>
                        <td>
                            @if (r.ExpirationDate.HasValue)
                            {
                                var isExpired = r.ExpirationDate.Value.Date < DateTime.UtcNow.Date;
                                var isNear = !isExpired && r.ExpirationDate.Value.Date <= DateTime.UtcNow.Date.AddDays(30);
                                <span class="badge bg-@(isExpired ? "danger" : isNear ? "warning" : "secondary")">
                                    @r.ExpirationDate.Value.ToString("dd.MM.yyyy")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-end fw-semibold">@r.Quantity @r.Unit</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>