@{
    ViewData["Title"] = "Импорт номенклатуры из Excel";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between">
        <h1 class="m-0">@ViewData["Title"]</h1>
        <a class="btn btn-outline-secondary" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>К списку
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Загрузите Excel файл с колонками: Наименование, Единица, Тип, Описание
        </div>

        <form method="post" enctype="multipart/form-data" class="vci-touch-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-4">
                <label class="form-label required">Выберите файл Excel (.xlsx)</label>
                <input type="file" name="file" class="form-control" accept=".xlsx" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-upload me-1"></i>Импортировать
                </button>
                <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
            </div>
        </form>
    </div>
</div>
