@model VentCleanInventory.Web.Areas.Dispatcher.Models.NomenclatureEditViewModel

@{
    ViewData["Title"] = "Редактировать номенклатуру";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Dispatcher" asp-controller="Nomenclature" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Unit" class="form-label"></label>
                    <input asp-for="Unit" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="MinStockQuantity" class="form-label"></label>
                    <input asp-for="MinStockQuantity" class="form-control" type="number" step="0.1" min="0" />
                    <div class="form-text">0 = автозаказ отключён</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="PreferredSupplierId" class="form-label"></label>
                    <select asp-for="PreferredSupplierId" class="form-select">
                        <option value="">— Не выбран —</option>
                        @foreach (var s in (List<VentCleanInventory.Web.Data.Entities.Organization>)ViewBag.Suppliers)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsEquipment" class="form-check-input" id="isEquipmentCheck" />
                        <label asp-for="IsEquipment" class="form-check-label" for="isEquipmentCheck"></label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
