@model VentCleanInventory.Web.Areas.Dispatcher.Models.Receipts.ReceiptCreateViewModel

@{
    ViewData["Title"] = "Приёмка товаров";
    var info = TempData["Info"] as string;
}

@if (!string.IsNullOrWhiteSpace(info))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@info
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Dispatcher" asp-controller="DispatcherHome" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="vci-touch-form" id="receiptForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="SupplierId" class="form-label">Поставщик</label>
                    <select asp-for="SupplierId" class="form-select">
                        <option value="">— не выбран —</option>
                        @foreach (var s in Model.Suppliers)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Note" class="form-label">Примечание</label>
                    <input asp-for="Note" class="form-control" placeholder="Дополнительная информация..." />
                    <span asp-validation-for="Note" class="text-danger small"></span>
                </div>
            </div>

            <h6 class="mt-4 mb-3"><i class="bi bi-list-ul me-2"></i>Позиции</h6>

            <div class="table-responsive">
                <table class="table table-borderless mb-3" id="linesTable">
                    <thead>
                    <tr>
                        <th>Номенклатура</th>
                        <th style="width: 90px">Кол-во</th>
                        <th style="width: 100px">Цена</th>
                        <th style="width: 130px">Срок год.</th>
                        <th style="width: 100px">Партия</th>
                        <th style="width: 50px"></th>
                    </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.Lines.Count; i++)
                    {
                        <tr>
                            <td>
                                <select asp-for="Lines[i].NomenclatureId" class="form-select">
                                    <option value="">— выберите —</option>
                                    @foreach (var n in Model.Nomenclatures)
                                    {
                                        <option value="@n.Id">@n.Name (@(n.IsEquipment ? "оборуд." : "расх."))</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <input asp-for="Lines[i].Quantity" class="form-control text-end" />
                            </td>
                            <td>
                                <input asp-for="Lines[i].UnitPrice" class="form-control text-end" />
                            </td>
                            <td>
                                <input asp-for="Lines[i].ExpirationDate" class="form-control" type="date" />
                            </td>
                            <td>
                                <input asp-for="Lines[i].BatchNumber" class="form-control" />
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-outline-primary mb-4" onclick="addRow()">
                <i class="bi bi-plus-lg me-1"></i>Добавить строку
            </button>

            <hr class="my-4">

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i>Провести
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const nomenclaturesHtml = `@Html.Raw(string.Join("", Model.Nomenclatures.Select(n => $"<option value=\\\"{n.Id}\\\">{System.Net.WebUtility.HtmlEncode(n.Name)} ({(n.IsEquipment ? "оборуд." : "расх.")})</option>")))`;

        function addRow() {
            const tbody = document.querySelector('#linesTable tbody');
            const index = tbody.querySelectorAll('tr').length;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>
                  <select class="form-select" name="Lines[${index}].NomenclatureId">
                    <option value="">— выберите —</option>
                    ${nomenclaturesHtml}
                  </select>
                </td>
                <td><input class="form-control text-end" name="Lines[${index}].Quantity" value="1" /></td>
                <td><input class="form-control text-end" name="Lines[${index}].UnitPrice" /></td>
                <td><input class="form-control" name="Lines[${index}].ExpirationDate" type="date" /></td>
                <td><input class="form-control" name="Lines[${index}].BatchNumber" /></td>
                <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)"><i class="bi bi-x-lg"></i></button></td>
            `;
            tbody.appendChild(tr);
        }

        function removeRow(btn) {
            const tr = btn.closest('tr');
            if (!tr) return;
            tr.remove();
        }
    </script>
}