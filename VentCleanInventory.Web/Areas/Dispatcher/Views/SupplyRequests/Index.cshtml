@model IEnumerable<VentCleanInventory.Web.Data.Entities.SupplyRequest>

@{
    ViewData["Title"] = "Поставки";
    var selected = Context.Request.Query["status"];
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Dispatcher" asp-controller="DispatcherHome" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Создать запрос
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="card-body">
        <div class="btn-group mb-3 flex-wrap" role="group">
            <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(selected) ? "btn-primary" : "btn-outline-secondary")">Активные</a>
            <a asp-action="Index" asp-route-status="1" class="btn btn-sm @(selected == "1" ? "btn-primary" : "btn-outline-secondary")">Новые</a>
            <a asp-action="Index" asp-route-status="2" class="btn btn-sm @(selected == "2" ? "btn-primary" : "btn-outline-secondary")">Отправлены</a>
            <a asp-action="Index" asp-route-status="3" class="btn btn-sm @(selected == "3" ? "btn-primary" : "btn-outline-secondary")">Подтверждены</a>
            <a asp-action="Index" asp-route-status="5" class="btn btn-sm @(selected == "5" ? "btn-primary" : "btn-outline-secondary")">Выполнены</a>
            <a asp-action="Index" asp-route-status="6" class="btn btn-sm @(selected == "6" ? "btn-primary" : "btn-outline-secondary")">Отменены</a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info">Нет запросов на поставку.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Дата</th>
                            <th>Поставщик</th>
                            <th>Состав</th>
                            <th>Статус</th>
                            <th style="width: 160px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.Number</td>
                                <td>@r.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>@(r.Organization?.Name ?? "—")</td>
                                <td>
                                    <ul class="list-unstyled mb-0">
                                        @foreach (var i in r.Items)
                                        {
                                            <li>@i.Nomenclature?.Name — @i.Quantity.ToString("N1") @i.Nomenclature?.Unit</li>
                                        }
                                    </ul>
                                </td>
                                <td>
                                    @switch (r.Status)
                                    {
                                        case SupplyRequestStatus.New: <span class="badge bg-warning text-dark">Новый</span> break;
                                        case SupplyRequestStatus.Sent: <span class="badge bg-info text-dark">Отправлен</span> break;
                                        case SupplyRequestStatus.Confirmed: <span class="badge bg-primary">Подтверждён</span> break;
                                        case SupplyRequestStatus.Partial: <span class="badge bg-secondary">Частично</span> break;
                                        case SupplyRequestStatus.Completed: <span class="badge bg-success">Выполнен</span> break;
                                        case SupplyRequestStatus.Cancelled: <span class="badge bg-danger">Отменён</span> break;
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        @if (r.Status == SupplyRequestStatus.New)
                                        {
                                            <form asp-action="Send" asp-route-id="@r.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success" title="Отправить поставщику">
                                                    <i class="bi bi-send"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Отменить запрос №@r.Number?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Отменить">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (r.Status == SupplyRequestStatus.Sent)
                                        {
                                            <a asp-area="Dispatcher" asp-controller="SupplyContract" asp-action="Export" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary" title="Скачать договор">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </a>
                                            <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Отменить запрос №@r.Number?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Отменить">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (r.Status == SupplyRequestStatus.Confirmed || r.Status == SupplyRequestStatus.Partial || r.Status == SupplyRequestStatus.Completed)
                                        {
                                            <a asp-area="Dispatcher" asp-controller="SupplyContract" asp-action="Export" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary" title="Скачать договор">
                                                <i class="bi bi-file-earmark-text"></i>
                                            </a>
                                        }
                                        @if (r.Status == SupplyRequestStatus.Confirmed)
                                        {
                                            <a asp-action="Receive" asp-route-id="@r.Id" class="btn btn-sm btn-success">
                                                <i class="bi bi-box-arrow-in-down"></i> Принять
                                            </a>
                                            <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Отменить запрос №@r.Number?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Отменить">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
