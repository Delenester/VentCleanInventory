@model VentCleanInventory.Web.Areas.Dispatcher.Models.SupplyRequests.SupplyRequestCreateViewModel

@{
    ViewData["Title"] = "Новый запрос на поставку";
}

<div class="page-header d-flex align-items-center gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="m-0">@ViewData["Title"]</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" id="requestForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="SupplierId" class="form-label">Поставщик</label>
                    <select asp-for="SupplierId" class="form-select">
                        <option value="">— выберите —</option>
                        @foreach (var s in Model.Suppliers)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                    <span asp-validation-for="SupplierId" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Note" class="form-label">Примечание</label>
                    <input asp-for="Note" class="form-control" placeholder="Дополнительная информация..." />
                </div>
            </div>

            <h6 class="mt-4 mb-3"><i class="bi bi-list-ul me-2"></i>Позиции</h6>

            <div class="table-responsive">
                <table class="table table-bordered mb-3" id="linesTable">
                    <thead>
                        <tr>
                            <th>Номенклатура</th>
                            <th style="width: 120px">Количество</th>
                            <th style="width: 50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Lines.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select asp-for="Lines[i].NomenclatureId" class="form-select">
                                        <option value="">— выберите —</option>
                                        @foreach (var n in Model.Nomenclatures)
                                        {
                                            <option value="@n.Id">@n.Name (@n.Unit)</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input asp-for="Lines[i].Quantity" class="form-control text-end" />
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <button type="button" class="btn btn-outline-primary mb-4" onclick="addRow()">
                <i class="bi bi-plus-lg me-1"></i>Добавить строку
            </button>

            <hr class="my-4">

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i>Создать запрос
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const nomenclaturesHtml = `@Html.Raw(string.Join("", Model.Nomenclatures.Select(n => $"<option value=\\\"{n.Id}\\\">{System.Net.WebUtility.HtmlEncode($"{n.Name} ({n.Unit})")}</option>")))`;

        function addRow() {
            const tbody = document.querySelector('#linesTable tbody');
            const index = tbody.querySelectorAll('tr').length;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>
                  <select class="form-select" name="Lines[${index}].NomenclatureId">
                    <option value="">— выберите —</option>
                    ${nomenclaturesHtml}
                  </select>
                </td>
                <td><input class="form-control text-end" name="Lines[${index}].Quantity" value="1" /></td>
                <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)"><i class="bi bi-x-lg"></i></button></td>
            `;
            tbody.appendChild(tr);
        }

        function removeRow(btn) {
            var tr = btn.closest('tr');
            if (!tr) tr.remove();
        }
    </script>
}
