@model IEnumerable<VentCleanInventory.Web.Areas.Admin.Models.Users.UserListItemViewModel>

@{
    ViewData["Title"] = "Пользователи";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <a asp-area="Admin" asp-controller="AdminHome" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-action="Create">
                <i class="bi bi-plus-lg me-1"></i>Добавить
            </a>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Пользователи не найдены.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Логин</th>
                            <th>Имя</th>
                            <th>Email</th>
                            <th>Роли</th>
                            <th>Статус</th>
                            <th style="width: 180px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, i) in Model.Select((x, i) => (x, i)))
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@item.UserName</td>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>
                                    @foreach (var role in item.Roles)
                                    {
                                        <span class="badge bg-primary me-1">@role</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success">Одобрен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Ожидает</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        @if (!item.IsApproved)
                                        {
                                            <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Одобрить" onclick="return confirm('Одобрить пользователя?')">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Reject" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Отклонить" onclick="return confirm('Отклонить заявку?')">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Редактировать">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить" onclick="return confirm('Удалить пользователя?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
