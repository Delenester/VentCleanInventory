@model VentCleanInventory.Web.Areas.Admin.Models.Users.UserCreateViewModel

@{
    ViewData["Title"] = "Добавить пользователя";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Login" class="form-label"></label>
                    <input asp-for="Login" class="form-control" required />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
                <div class="col-12">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select" required>
                        <option value="">— выберите роль —</option>
                        <option value="Администратор">Администратор</option>
                        <option value="Диспетчер">Диспетчер</option>
                        <option value="Руководитель">Руководитель</option>
                        <option value="Мастер">Мастер</option>
                    </select>
                    <div class="form-text">Работникам учётную запись создаёт только администратор. Клиенты и поставщики регистрируются сами.</div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Создать</button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
