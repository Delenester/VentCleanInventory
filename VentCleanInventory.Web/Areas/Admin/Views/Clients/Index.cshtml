@model IEnumerable<VentCleanInventory.Web.Data.Entities.Organization>

@{
    ViewData["Title"] = "Клиенты (юр. лица)";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <a asp-area="Admin" asp-controller="AdminHome" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="m-0">@ViewData["Title"]</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Добавить
        </a>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>Клиенты не найдены.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>УНП</th>
                            <th>Организация</th>
                            <th>Адрес</th>
                            <th>Контакты</th>
                            <th style="width: 120px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, i) in Model.Select((x, i) => (x, i)))
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@item.Unp</td>
                                <td>@item.Name</td>
                                <td>@item.LegalAddress</td>
                                <td>@item.ContactInfo</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Редактировать">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить" onclick="return confirm('Удалить клиента?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
