@model VentCleanInventory.Web.Areas.Admin.Models.Clients.ClientCreateViewModel

@{
    ViewData["Title"] = "Добавить клиента";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Unp" class="form-label"></label>
                    <input asp-for="Unp" class="form-control" maxlength="9" required />
                    <span asp-validation-for="Unp" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="OrganizationName" class="form-label"></label>
                    <input asp-for="OrganizationName" class="form-control" required />
                    <span asp-validation-for="OrganizationName" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="LegalAddress" class="form-label"></label>
                    <input asp-for="LegalAddress" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="ContactInfo" class="form-label"></label>
                    <textarea asp-for="ContactInfo" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
