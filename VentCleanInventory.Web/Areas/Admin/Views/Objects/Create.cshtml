@model VentCleanInventory.Web.Areas.Admin.Models.Objects.ObjectCreateViewModel

@{
    ViewData["Title"] = "Добавить объект";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Admin" asp-controller="Objects" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="VentSystemType" class="form-label"></label>
                    <input asp-for="VentSystemType" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="AccessDifficulty" class="form-label"></label>
                    <input asp-for="AccessDifficulty" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Distance" class="form-label"></label>
                    <input asp-for="Distance" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Создать</button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
