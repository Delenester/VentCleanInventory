@{
    ViewData["Title"] = "Экспорт номенклатуры в Excel";
}

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between">
        <h1 class="m-0">@ViewData["Title"]</h1>
        <a class="btn btn-outline-secondary" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>К списку
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Скачать Excel файл со всеми позициями номенклатуры.
        </div>

        <form method="post" class="vci-touch-form">
            @Html.AntiForgeryToken()

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-download me-1"></i>Скачать
                </button>
                <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
            </div>
        </form>
    </div>
</div>
