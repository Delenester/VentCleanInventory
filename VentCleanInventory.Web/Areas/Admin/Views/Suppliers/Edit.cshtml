@model VentCleanInventory.Web.Areas.Admin.Models.Suppliers.SupplierEditViewModel

@{
    ViewData["Title"] = "Редактировать поставщика";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <a asp-area="Admin" asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="m-0">@ViewData["Title"]</h1>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Unp" class="form-label"></label>
                    <input asp-for="Unp" class="form-control" maxlength="9" />
                </div>
                <div class="col-12">
                    <label asp-for="LegalAddress" class="form-label"></label>
                    <input asp-for="LegalAddress" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="ContactInfo" class="form-label"></label>
                    <textarea asp-for="ContactInfo" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
